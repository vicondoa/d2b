{
  "$comment": "W3fu1 H4 malicious fixture — derived bridge ifname is 17 bytes (>= IFNAMSIZ-1 = 15), which the emitter MUST reject with `ifname-too-long`.",
  "schemaVersion": "v2",
  "bundleVersion": "0.4.0",
  "site": {
    "hostLanCidr": "192.0.2.0/24",
    "modulesDisabledSysctlPolicy": "preload-required",
    "stateDir": "/var/lib/nixling",
    "runtimeDir": "/run/nixling"
  },
  "environments": [
    {
      "env": "verylongenvname",
      "subnet": "10.42.1.0/24",
      "bridge": "nl-verylongenvname-deadbeef",
      "natUpstream": "eth0",
      "ipv6Sysctls": {"all.disable_ipv6": "1"},
      "dnsmasqBoundIp": "10.42.1.1"
    }
  ],
  "nftables": {"table": "inet nixling", "ownershipMarker": "nixling-owned", "priority": -100},
  "networkManager": {"managed": false, "unmanagedDropIn": "/etc/NetworkManager/conf.d/nixling-unmanaged.conf"},
  "hostsFile": {"path": "/etc/hosts", "markerBegin": "# nixling-managed-begin", "markerEnd": "# nixling-managed-end"},
  "kernelModules": {"allowed": ["tun"], "modulesDisabledPolicy": "preload-required"},
  "bridgePortFlags": {"learning": true, "flooding": false, "mcastFlood": false, "broadcastFlood": true},
  "firewallCoexistence": {"manager": "networkmanager", "allow": [], "refuse": []},
  "ifnameMapping": {"scheme": "hash-truncate-8", "prefix": "nl-", "max_ifname_bytes": 15},
  "ch": {"minVersion": "v40", "netHandoffMode": "tap-fd"},
  "fdOwnership": [],
  "cloudHypervisorCapabilities": [],
  "_expectedRejection": {
    "code": "ifname-too-long",
    "reason": "environments[0].bridge is 27 bytes; IfName invariant requires <= 15 bytes"
  }
}
