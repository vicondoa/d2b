{
  "name": "corp-vm",
  "env": "work",
  "services": {
    "d2b": "inactive",
    "microvm": "inactive",
    "virtiofsd": "inactive",
    "gpu": null,
    "snd": null,
    "swtpm": null
  },
  "current": null,
  "booted": null,
  "pendingRestart": false,
  "runtime": "unknown (daemon-experimental, W4 not landed)",
  "declaredRoles": [
    "host-reconcile",
    "store-virtiofs-preflight",
    "virtiofsd",
    "virtiofsd",
    "virtiofsd",
