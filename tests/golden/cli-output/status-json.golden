    "unix-socket-exists:/run/d2b/vms/corp-vm/d2b-meta.sock",
    "unix-socket-exists:/run/d2b/vms/corp-vm/d2b-hkeys.sock",
    "unix-socket-exists:/run/d2b/vms/corp-vm/d2b-ssh-host.sock",
    "api-socket-info:/var/lib/d2b/vms/corp-vm/corp-vm.sock",
    "tcp-port:10.20.0.10:22"
  ],
  "runnerParity": {
    "declaredRunner": "/nix/store/139kn3xbgap472rgr7nxs3safamq7n78-microvm-qemu-corp-vm",
