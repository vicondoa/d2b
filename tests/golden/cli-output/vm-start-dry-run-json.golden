# Rust dry-run snapshot only; bash side comparison gated on Tier-2 self-hosted KVM runner.
{
  "command": "vm start",
  "dag": {
    "edges": [
      {
        "from": "host-reconcile",
        "to": "store-preflight"
      },
      {
        "from": "store-preflight",
        "to": "virtiofsd-ro-store"
      },
      {
        "from": "virtiofsd-ro-store",
        "to": "ch"
      },
      {
        "from": "ch",
        "to": "guest-control-health"
      }
    ],
    "nodes": [
      {
        "id": "host-reconcile",
        "role": "host-reconcile"
      },
      {
        "id": "store-preflight",
        "role": "store-virtiofs-preflight"
      },
      {
        "id": "virtiofsd-ro-store",
        "role": "virtiofsd"
      },
      {
        "id": "ch",
        "role": "cloud-hypervisor-runner"
      },
      {
        "id": "guest-control-health",
        "role": "guest-control-health"
      }
    ]
  },
  "mode": "dry-run",
  "notes": "vm dry-run reports the DAG the supervisor would drive (start: topo order; stop: reverse topo). --apply routes through d2bd → broker (v1.0 daemon-only per ADR 0015).",
  "stopOrder": null,
  "vm": "corp-vm"
}
