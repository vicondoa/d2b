role: launcher
effective uid: 1000
sockets:
- public: reachable (version 0.4.0-test)
- broker: unreachable
allowed subcommands: audio, auth status, boot, build, console, down, gc, generations, host check, keys list, list, restart, rollback, rotate-known-host, status, switch, test, trust, up, usb
denied subcommands:
- audit: audit requires admin role in `nixling.site.adminUsers`.
