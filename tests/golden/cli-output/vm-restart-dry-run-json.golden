# Rust dry-run snapshot only; bash side comparison gated on Tier-2 self-hosted KVM runner.
{
  "command": "vm restart",
  "dag": {
    "edges": [
      {
        "from": "host-reconcile",
        "to": "store-preflight"
      },
      {
        "from": "store-preflight",
        "to": "virtiofsd-ro-store"
      },
      {
        "from": "virtiofsd-ro-store",
        "to": "ch"
      },
      {
        "from": "ch",
        "to": "ssh-ready"
      }
    ],
    "nodes": [
      {
        "id": "host-reconcile",
        "role": "host-reconcile"
      },
      {
        "id": "store-preflight",
        "role": "store-virtiofs-preflight"
      },
      {
        "id": "virtiofsd-ro-store",
        "role": "virtiofsd"
      },
      {
        "id": "ch",
        "role": "cloud-hypervisor-runner"
      },
      {
        "id": "ssh-ready",
        "role": "guest-ssh-readiness"
      }
    ]
  },
  "mode": "dry-run",
  "notes": "vm dry-run reports the DAG the supervisor would drive (start: topo order; stop: reverse topo). --apply uses the daemon-first bridge.",
  "stopOrder": [
    "ssh-ready",
    "ch",
    "virtiofsd-ro-store",
    "store-preflight",
    "host-reconcile"
  ],
  "vm": "corp-vm"
}
