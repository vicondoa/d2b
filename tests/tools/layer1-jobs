#!/usr/bin/env bash
set -euo pipefail

HERE=$(dirname "$(readlink -f "$0")")
ROOT=${ROOT:-$(cd "$HERE/../.." && pwd)}

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$ROOT/tests/tools/layer1-jobs.py" "$@"
fi

if ! command -v nix >/dev/null 2>&1; then
  echo "layer1-jobs: python3 not found and nix is unavailable" >&2
  exit 127
fi

exec nix shell --quiet --no-warn-dirty --inputs-from "$ROOT" nixpkgs#python3 \
  --command python3 "$ROOT/tests/tools/layer1-jobs.py" "$@"
