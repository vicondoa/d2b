{
  "uid": "nixling-overview",
  "title": "Nixling Overview",
  "tags": ["nixling", "v0.2.0"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(nixling_vm_ch_api_up, env)",
        "definition": "label_values(nixling_vm_ch_api_up, env)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "options": []
      },
      {
        "name": "vm",
        "label": "VM",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(nixling_vm_ch_api_up{env=~\"${env:regex}\"}, vm)",
        "definition": "label_values(nixling_vm_ch_api_up{env=~\"${env:regex}\"}, vm)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "VM state by env",
      "description": "Joins the active nixling_vm_state series with CH API availability and scrape recency. Assumes one state label is active per VM.",
      "gridPos": {"h": 10, "w": 14, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true, "cellHeight": "sm", "footer": {"show": false}},
      "targets": [
        {
          "refId": "A",
          "expr": "max by (vm, env, role, state) (nixling_vm_state{env=~\"${env:regex}\", vm=~\"${vm:regex}\"} == 1)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "max by (vm, env, role) (nixling_vm_ch_api_up{env=~\"${env:regex}\", vm=~\"${vm:regex}\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "max by (vm, env, role) (time() - nixling_vm_last_scrape_timestamp_seconds{env=~\"${env:regex}\", vm=~\"${vm:regex}\"})",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {"id": "labelsToFields", "options": {"mode": "columns"}},
        {"id": "joinByField", "options": {"byField": "vm", "mode": "outer"}},
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "Time 1": true, "Time 2": true},
            "renameByName": {
              "state": "last_state",
              "Value": "state_active",
              "Value 1": "ch_api_up",
              "Value 2": "last_scrape_age_seconds"
            }
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reachability by env",
      "description": "Repeated once per selected environment. Shows running VMs divided by total declared VMs in that env.",
      "gridPos": {"h": 5, "w": 10, "x": 14, "y": 0},
      "repeat": "env",
      "repeatDirection": "h",
      "maxPerRow": 4,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 1}]}, "mappings": []},
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(max by (vm) (nixling_vm_state{env=\"$env\", state=\"Running\"} == 1)) / clamp_min(count(max by (vm) (nixling_vm_ch_api_up{env=\"$env\"})), 1)",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CH API availability",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "nixling_vm_ch_api_up{env=~\"${env:regex}\", vm=~\"${vm:regex}\"}",
          "legendFormat": "{{vm}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Vsock relay health (fallback: scrape age)",
      "description": "Fallback panel because nixling does not currently expose host systemd-unit metrics for nixling-otel-relay@<vm>.service.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - nixling_vm_last_scrape_timestamp_seconds{env=~\"${env:regex}\", vm=~\"${vm:regex}\"}",
          "legendFormat": "{{vm}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Degraded shutdown markers",
      "description": "VMs with uncleared graceful-shutdown degraded markers by bounded reason enum.",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}]}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (nixling_vm_shutdown_degraded{env=~\"${env:regex}\", vm=~\"${vm:regex}\"})",
          "instant": true,
          "legendFormat": "{{reason}}"
        }
      ]
    }
  ]
}
