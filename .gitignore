# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Nix
result
result-*
.direnv/

# Editor
*.swp
*.swo
*~
.idea/
.vscode/

# Test artifacts
tests/smoke-run-log.txt
/tmp/d2b-*.log

# W2 transient test caches + logs (smoke/cache scratch, daemon test agent-tmp,
# repo-local scratch registries, static.sh flock)
.agent-tmp/
.assertions-eval.*/
.audio-gitcfg.*/
.broad-caps-invariant.*/
.broker-*/
.bundle-drift.*/
.cli-contract-coverage.*/
.cli-contract-coverage.log
.cli-rust-native-cache/
.cli-rust-native.log
.cli-json.*/
.cli-json-drift.*/
.cli-legacy-bash-dispatch.*/
.cli-rust-native-audit.*/
.cli-rust-native-auth-status.*/
.cli-rust-native-host-check.*/
.cli-rust-native-list.*/
.cli-rust-native-status.*/
.daemon-*/
.host-check.*/
.manifest-fuzz-bounded.*/
.manifest-gate.*/
.manifest-v04-roundtrip.*/
.d2b-cleanups.*
.d2b-scratch-registry
.d2b-smoke-cache.*/
.d2b-broker-layer1-target.*/
.d2b-rust-gate.*/
.d2b-stub-smoke.*/
.d2b-test.log
.observability-eval.*/
.opaque-key-ids.*/
.privileges-matrix.*/
.runner-shape-snapshot.log
.static-cache.*/
.static-gitcfg.*/
.static-sh.lock
.static-timing.log
.static-timing.log.*
.static-timing.raw
.static-timing.raw.*
.static-timing.status.*
.template-flake-check.*/
.uid0-invariant.*/
.vms-json-parity.*/
.world-readable-invariant.*/
.writable-paths-invariant.*/
.static-fast.lock
packages/*/t/
.copilot-*
/.ttrpc-api-fit-spike.*/
.*-eval.log

# CI sccache local-disk backend (restored/saved by actions/cache in test-rust).
.sccache/

# Toolchain-scoped Cargo gate outputs. Developer Cargo commands continue to use
# packages/target; tests/test-rust.sh uses these isolated dirs so artifacts from
# another rustc version cannot poison the pinned gate.
packages/.d2b-gate-targets/

# Broker feature-pass target dirs (deterministic siblings of the broker target
# dir, kept stable so sccache cache keys don't churn — see tests/test-rust.sh).
packages/d2b-priv-broker/target-layer1/
packages/d2b-priv-broker/target-fakebackends/

# Panel-review output must never be committed — it belongs in the
# session workspace, not the repo. (Removed a stray panel-w-fu-fu-rollup/
# that a prior run wrote into the repo when /tmp was unavailable.)
panel-*/
