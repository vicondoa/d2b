# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Nix
result
result-*
.direnv/

# Editor
*.swp
*.swo
*~
.idea/
.vscode/

# Test artifacts
/tmp/nixling-*.log

# W2 transient test caches + logs (smoke/cache scratch, daemon test agent-tmp,
# repo-local scratch registries, static.sh flock)
.agent-tmp/
.assertions-eval.*/
.audio-gitcfg.*/
.broad-caps-invariant.*/
.broker-*/
.bundle-drift.*/
.cli-contract-coverage.*/
.cli-contract-coverage.log
.cli-rust-native-cache/
.cli-rust-native.log
.cli-json.*/
.cli-json-drift.*/
.cli-legacy-bash-dispatch.*/
.cli-rust-native-audit.*/
.cli-rust-native-auth-status.*/
.cli-rust-native-host-check.*/
.cli-rust-native-list.*/
.cli-rust-native-status.*/
.daemon-*/
.host-check.*/
.manifest-fuzz-bounded.*/
.manifest-gate.*/
.manifest-v04-roundtrip.*/
.nl-cleanups.*
.nl-scratch-registry
.nl-smoke-cache.*/
.nixling-rust-gate.*/
.nixling-stub-smoke.*/
.nixling-test.log
.observability-eval.*/
.opaque-key-ids.*/
