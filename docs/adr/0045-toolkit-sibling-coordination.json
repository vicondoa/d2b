  "globalBlockers": [
    {
      "id": "client-endpoint-bootstrap",
      "detail": "The canonical client accepts an owned route, endpoint policy, credentials, and transport; live public endpoint discovery and bootstrap remain owned by the core-control service API."
    },
    {
      "id": "runtime-adapter",
      "detail": "The canonical client and session crates use Tokio while existing wlterm and WeezTerm integrations use async-io or smol; consumers must use an explicit adapter or runtime boundary without copying protocol code."
    },
    {
      "id": "client-redaction-wrapper",
      "detail": "No canonical general-purpose client wire-redaction wrapper exists. Consumers may keep presentation-only models but cannot carry forward the old wire-serializable wrapper."
    },
    {
      "id": "content-freeze",
      "detail": "Consumer branches that use daemon, shell, notify, or Wayland methods cannot finalize until the owning service APIs are content-frozen."
    }
  ]
