  "globalBlockers": [
    {
      "id": "client-endpoint-bootstrap",
      "detail": "The client toolkit exposes the frozen daemon and user/desktop service clients. It still accepts an owned route, endpoint policy, credentials, and transport; live endpoint and credential acquisition remain integrated runtime behavior rather than distribution-owned discovery."
    },
    {
      "id": "runtime-adapter",
      "detail": "The canonical client and session crates use Tokio while existing wlterm and WeezTerm integrations use async-io or smol; consumers must use an explicit adapter or runtime boundary without copying protocol code."
    },
    {
      "id": "client-redaction-wrapper",
      "detail": "No canonical general-purpose client wire-redaction wrapper exists. Consumers may keep presentation-only models but cannot carry forward the old wire-serializable wrapper."
    },
    {
      "id": "downstream-refresh",
      "detail": "The wlcontrol, wlterm, and WeezTerm audited heads still consume the prior client-toolkit revision. Their follow-ups are running against the frozen W6 source and current distribution fingerprint."
    }
  ]
