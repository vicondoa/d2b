{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ManifestV04",
  "description": "Typed v0.4.0 public vms.json manifest with reserved sentinels and dynamic VM keys.",
  "type": "object",
  "required": [
    "_manifest",
    "_observability"
  ],
  "properties": {
    "_manifest": {
      "$ref": "#/definitions/ManifestMeta"
    },
    "_observability": {
      "$ref": "#/definitions/ObservabilityMeta"
    }
  },
  "patternProperties": {
    "^[a-z][a-z0-9-]*$": {
      "$ref": "#/definitions/VmEntry"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ManifestMeta": {
      "type": "object",
      "required": [
        "manifestVersion"
      ],
      "properties": {
        "manifestVersion": {
          "description": "Manifest schema version. Must equal the parser's supported version.",
          "type": "integer",
          "enum": [
            6
          ]
        }
      },
      "additionalProperties": false
    },
    "ObservabilityMeta": {
      "type": "object",
      "required": [
        "enabled",
        "obsVsockCid",
        "obsVsockHostSocket",
        "signozOtlpGrpcPort",
        "signozOtlpHttpPort",
        "signozUrl",
        "vmName"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "obsVsockCid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "obsVsockHostSocket": {
          "type": "string"
        },
        "signozOtlpGrpcPort": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "signozOtlpHttpPort": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "signozUrl": {
          "type": "string"
        },
        "vmName": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "RuntimeCapabilities": {
      "description": "Runtime/provider support matrix. These flags describe support, not whether a VM currently enables a feature.",
      "type": "object",
      "required": [
        "configSync",
        "display",
        "exec",
        "guestControl",
        "inGuestObservability",
        "keys",
        "lifecycle",
        "ssh",
        "storeSync",
        "usbHotplug"
      ],
      "properties": {
        "configSync": {
          "type": "boolean"
        },
        "display": {
          "type": "boolean"
        },
        "exec": {
          "type": "boolean"
        },
        "guestControl": {
          "type": "boolean"
        },
        "inGuestObservability": {
          "type": "boolean"
        },
        "keys": {
          "type": "boolean"
        },
        "lifecycle": {
          "type": "boolean"
        },
        "ssh": {
          "type": "boolean"
        },
        "storeSync": {
          "type": "boolean"
        },
        "usbHotplug": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "RuntimeKind": {
      "description": "VM runtime family.",
      "type": "string",
      "enum": [
        "nixos",
        "qemu-media"
      ]
    },
    "RuntimeMetadata": {
      "description": "Runtime/provider metadata shared by the public manifest and private bundle artifacts.",
      "type": "object",
      "required": [
        "capabilities",
        "kind",
        "provider"
      ],
      "properties": {
        "capabilities": {
          "$ref": "#/definitions/RuntimeCapabilities"
        },
        "kind": {
          "$ref": "#/definitions/RuntimeKind"
        },
        "provider": {
          "$ref": "#/definitions/RuntimeProvider"
        }
      },
      "additionalProperties": false
    },
    "RuntimeProvider": {
      "description": "Local runtime provider identity.",
      "type": "object",
      "required": [
        "driver",
        "id",
        "type"
      ],
      "properties": {
        "driver": {
          "$ref": "#/definitions/RuntimeProviderDriver"
        },
        "id": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/RuntimeProviderType"
        }
      },
      "additionalProperties": false
    },
    "RuntimeProviderDriver": {
      "description": "Provider driver family.",
      "type": "string",
      "enum": [
        "cloud-hypervisor",
        "qemu"
      ]
    },
    "RuntimeProviderType": {
      "description": "Provider locality class.",
      "type": "string",
      "enum": [
        "local"
      ]
    },
    "VmEntry": {
      "type": "object",
      "required": [
        "audio",
        "graphics",
        "isNetVm",
        "name",
        "observability",
        "runtime",
        "stateDir",
        "tap",
        "tpm",
        "usbipYubikey"
      ],
      "properties": {
        "apiSocket": {
          "type": [
            "string",
            "null"
          ]
        },
        "audio": {
          "type": "boolean"
        },
        "audioService": {
          "type": [
            "string",
            "null"
          ]
        },
        "audioStateFile": {
          "type": [
            "string",
            "null"
          ]
        },
        "bridge": {
          "type": [
            "string",
            "null"
          ]
        },
        "env": {
          "type": [
            "string",
            "null"
          ]
        },
        "gpuSocket": {
          "type": [
            "string",
            "null"
          ]
        },
        "graphics": {
          "type": "boolean"
        },
        "isNetVm": {
          "type": "boolean"
        },
        "lan": {
          "anyOf": [
            {
              "$ref": "#/definitions/VmLanPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "mssClamp": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0.0
        },
        "mtu": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0.0
        },
        "name": {
          "type": "string"
        },
        "netVm": {
          "type": [
            "string",
            "null"
          ]
        },
        "observability": {
          "$ref": "#/definitions/VmObservability"
        },
        "runtime": {
          "$ref": "#/definitions/RuntimeMetadata"
        },
        "sshUser": {
          "type": [
            "string",
            "null"
          ]
        },
        "stateDir": {
          "type": "string"
        },
        "staticIp": {
          "type": [
            "string",
            "null"
          ]
        },
        "tap": {
          "type": "string"
        },
        "tpm": {
          "type": "boolean"
        },
        "tpmSocket": {
          "type": [
            "string",
            "null"
          ]
        },
        "usbipYubikey": {
          "type": "boolean"
        },
        "usbipdHostIp": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "VmLanPolicy": {
      "type": "object",
      "required": [
        "allowEastWest",
        "effectiveEastWest"
      ],
      "properties": {
        "allowEastWest": {
          "type": "boolean"
        },
        "effectiveEastWest": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "VmObservability": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "agentSocket": {
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "vsockCid": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "vsockHostSocket": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
