{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ManifestV04",
  "description": "Typed v0.4.0 public vms.json manifest with reserved sentinels and dynamic VM keys.",
  "type": "object",
  "required": [
    "_manifest",
    "_observability"
  ],
  "properties": {
    "_manifest": {
      "$ref": "#/definitions/ManifestMeta"
    },
    "_observability": {
      "$ref": "#/definitions/ObservabilityMeta"
    }
  },
  "patternProperties": {
    "^[a-z][a-z0-9-]*$": {
      "$ref": "#/definitions/VmEntry"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ManifestMeta": {
      "type": "object",
      "required": [
        "manifestVersion"
      ],
      "properties": {
        "manifestVersion": {
          "description": "Manifest schema version. Must equal the parser's supported version.",
          "type": "integer",
          "enum": [
            7
          ]
        }
      },
      "additionalProperties": false
    },
    "ManifestShellName": {
      "type": "string",
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_][A-Za-z0-9._-]{0,63}$"
    },
    "ObservabilityMeta": {
      "type": "object",
      "required": [
        "enabled",
        "obsVsockCid",
        "obsVsockHostSocket",
        "signozOtlpGrpcPort",
        "signozOtlpHttpPort",
        "signozUrl",
        "vmName"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "obsVsockCid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "obsVsockHostSocket": {
          "type": "string"
        },
        "signozOtlpGrpcPort": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "signozOtlpHttpPort": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "signozUrl": {
          "type": "string"
        },
        "vmName": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "RuntimeAutostartPolicy": {
      "description": "Runtime-level autostart policy exposed in public summaries.",
      "type": "string",
      "enum": [
        "unknown",
        "host-boot-eligible",
        "manual-only",
        "disabled"
      ]
    },
    "RuntimeCapabilities": {
      "description": "Runtime/provider support matrix. These flags describe support, not whether a VM currently enables a feature.",
      "type": "object",
      "required": [
        "configSync",
        "display",
        "exec",
        "guestControl",
        "inGuestObservability",
        "keys",
        "lifecycle",
        "ssh",
        "storeSync",
        "usbHotplug"
      ],
      "properties": {
        "configSync": {
          "type": "boolean"
        },
        "display": {
          "type": "boolean"
        },
        "exec": {
          "type": "boolean"
        },
        "guestControl": {
          "type": "boolean"
        },
        "inGuestObservability": {
          "type": "boolean"
        },
        "keys": {
          "type": "boolean"
        },
        "lifecycle": {
          "type": "boolean"
        },
        "ssh": {
          "type": "boolean"
        },
        "storeSync": {
          "type": "boolean"
        },
        "usbHotplug": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "RuntimeDisplayCapabilities": {
      "description": "Display-side operations exposed by a runtime provider.",
      "type": "object",
      "required": [
        "display",
        "graphics",
        "video",
        "waylandProxy"
      ],
      "properties": {
        "display": {
          "type": "boolean"
        },
        "graphics": {
          "type": "boolean"
        },
        "video": {
          "type": "boolean"
        },
        "waylandProxy": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "RuntimeGuestCapabilities": {
      "description": "Guest-facing operations exposed by a runtime provider.",
      "type": "object",
      "required": [
        "configSync",
        "exec",
        "guestControl",
        "inGuestObservability",
        "keys",
        "ssh"
      ],
      "properties": {
        "configSync": {
          "type": "boolean"
        },
        "exec": {
          "type": "boolean"
        },
        "guestControl": {
          "type": "boolean"
        },
        "inGuestObservability": {
          "type": "boolean"
        },
        "keys": {
          "type": "boolean"
        },
        "shell": {
          "default": false,
          "type": "boolean"
        },
        "ssh": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "RuntimeKind": {
      "description": "VM runtime family.",
      "type": "string",
      "enum": [
        "nixos",
        "qemu-media"
      ]
    },
    "RuntimeLifecycleCapabilities": {
      "description": "Lifecycle operations exposed by a runtime provider.",
      "type": "object",
      "required": [
        "hostPrepare",
        "restart",
        "start",
        "stop",
        "switch"
      ],
      "properties": {
        "hostPrepare": {
          "type": "boolean"
        },
        "restart": {
          "type": "boolean"
        },
        "start": {
          "type": "boolean"
        },
        "stop": {
          "type": "boolean"
        },
        "switch": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "RuntimeMediaCapabilities": {
      "description": "Media and hotplug operations exposed by a runtime provider.",
      "type": "object",
      "required": [
        "qemuMedia",
        "removableMedia",
        "usbHotplug"
      ],
      "properties": {
        "qemuMedia": {
          "type": "boolean"
        },
        "removableMedia": {
          "type": "boolean"
        },
        "usbHotplug": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "RuntimeMetadata": {
      "description": "Runtime/provider metadata shared by the public manifest and private bundle artifacts.",
      "type": "object",
      "required": [
        "capabilities",
        "kind",
        "provider"
      ],
      "properties": {
        "autostartPolicy": {
          "$ref": "#/definitions/RuntimeAutostartPolicy"
        },
        "capabilities": {
          "$ref": "#/definitions/RuntimeCapabilities"
        },
        "kind": {
          "$ref": "#/definitions/RuntimeKind"
        },
        "operationCapabilities": {
          "$ref": "#/definitions/RuntimeOperationCapabilities"
        },
        "provider": {
          "$ref": "#/definitions/RuntimeProvider"
        },
        "services": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RuntimeServiceSummary"
          }
        }
      },
      "additionalProperties": false
    },
    "RuntimeOperationCapabilities": {
      "description": "Runtime/provider operation support grouped by public feature axis.",
      "type": "object",
      "required": [
        "display",
        "guest",
        "lifecycle",
        "media",
        "storage"
      ],
      "properties": {
        "display": {
          "$ref": "#/definitions/RuntimeDisplayCapabilities"
        },
        "guest": {
          "$ref": "#/definitions/RuntimeGuestCapabilities"
        },
        "lifecycle": {
          "$ref": "#/definitions/RuntimeLifecycleCapabilities"
        },
        "media": {
          "$ref": "#/definitions/RuntimeMediaCapabilities"
        },
        "storage": {
          "$ref": "#/definitions/RuntimeStorageCapabilities"
        }
      },
      "additionalProperties": false
    },
    "RuntimeProvider": {
      "description": "Local runtime provider identity.",
      "type": "object",
      "required": [
        "driver",
        "id",
        "type"
      ],
      "properties": {
        "driver": {
          "$ref": "#/definitions/RuntimeProviderDriver"
        },
        "id": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/RuntimeProviderType"
        }
      },
      "additionalProperties": false
    },
    "RuntimeProviderDriver": {
      "description": "Provider driver family.",
      "type": "string",
      "enum": [
        "cloud-hypervisor",
        "crosvm",
        "qemu"
      ]
    },
    "RuntimeProviderType": {
      "description": "Provider locality class.",
      "type": "string",
      "enum": [
        "local"
      ]
    },
    "RuntimeServiceRole": {
      "description": "Normalized public role for a runtime service, derived from process roles.",
      "type": "string",
      "enum": [
        "host",
        "hypervisor",
        "storage",
        "tpm",
        "display",
        "audio",
        "video",
        "network",
        "guest-control",
        "usb",
        "observability"
      ]
    },
    "RuntimeServiceSummary": {
      "description": "Public service summary that can be derived from the private process DAG.",
      "type": "object",
      "required": [
        "id",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "optional": {
          "default": false,
          "type": "boolean"
        },
        "role": {
          "$ref": "#/definitions/RuntimeServiceRole"
        }
      },
      "additionalProperties": false
    },
    "RuntimeStorageCapabilities": {
      "description": "Storage operations exposed by a runtime provider.",
      "type": "object",
      "required": [
        "storeSync",
        "virtiofs",
        "volumes"
      ],
      "properties": {
        "storeSync": {
          "type": "boolean"
        },
        "virtiofs": {
          "type": "boolean"
        },
        "volumes": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "VmEntry": {
      "type": "object",
      "required": [
        "audio",
        "graphics",
        "isNetVm",
        "name",
        "observability",
        "runtime",
        "stateDir",
        "tap",
        "tpm",
        "usbipYubikey"
      ],
      "properties": {
        "apiSocket": {
          "type": [
            "string",
            "null"
          ]
        },
        "audio": {
          "type": "boolean"
        },
        "audioService": {
          "type": [
            "string",
            "null"
          ]
        },
        "audioStateFile": {
          "type": [
            "string",
            "null"
          ]
        },
        "bridge": {
          "type": [
            "string",
            "null"
          ]
        },
        "env": {
          "type": [
            "string",
            "null"
          ]
        },
        "gpuSocket": {
          "type": [
            "string",
            "null"
          ]
        },
        "graphics": {
          "type": "boolean"
        },
        "isNetVm": {
          "type": "boolean"
        },
        "lan": {
          "anyOf": [
            {
              "$ref": "#/definitions/VmLanPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "lifecycle": {
          "default": {
            "gracefulShutdown": {
              "enable": true,
              "timeoutSeconds": null
            },
            "liveActivation": {
              "timeoutSeconds": null
            }
          },
          "allOf": [
            {
              "$ref": "#/definitions/VmLifecycle"
            }
          ]
        },
        "mssClamp": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0.0
        },
        "mtu": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "minimum": 0.0
        },
        "name": {
          "type": "string"
        },
        "netVm": {
          "type": [
            "string",
            "null"
          ]
        },
        "observability": {
          "$ref": "#/definitions/VmObservability"
        },
        "runtime": {
          "$ref": "#/definitions/RuntimeMetadata"
        },
        "securityKey": {
          "default": false,
          "type": "boolean"
        },
        "shell": {
          "anyOf": [
            {
              "$ref": "#/definitions/VmShellMetadata"
            },
            {
              "type": "null"
            }
          ]
        },
        "sshUser": {
          "type": [
            "string",
            "null"
          ]
        },
        "stateDir": {
          "type": "string"
        },
        "staticIp": {
          "type": [
            "string",
            "null"
          ]
        },
        "tap": {
          "type": "string"
        },
        "tpm": {
          "type": "boolean"
        },
        "tpmSocket": {
          "type": [
            "string",
            "null"
          ]
        },
        "usbipYubikey": {
          "type": "boolean"
        },
        "usbipdHostIp": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "VmGracefulShutdown": {
      "type": "object",
      "required": [
        "enable"
      ],
      "properties": {
        "enable": {
          "type": "boolean"
        },
        "timeoutSeconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "VmLanPolicy": {
      "type": "object",
      "required": [
        "allowEastWest",
        "effectiveEastWest"
      ],
      "properties": {
        "allowEastWest": {
          "type": "boolean"
        },
        "effectiveEastWest": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "VmLifecycle": {
      "type": "object",
      "required": [
        "gracefulShutdown"
      ],
      "properties": {
        "gracefulShutdown": {
          "$ref": "#/definitions/VmGracefulShutdown"
        },
        "liveActivation": {
          "default": {
            "timeoutSeconds": null
          },
          "allOf": [
            {
              "$ref": "#/definitions/VmLiveActivation"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "VmLiveActivation": {
      "type": "object",
      "properties": {
        "timeoutSeconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "VmObservability": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "agentSocket": {
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "vsockCid": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "vsockHostSocket": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "VmShellMetadata": {
      "type": "object",
      "required": [
        "defaultName",
        "enabled",
        "maxAttached",
        "maxSessions"
      ],
      "properties": {
        "defaultName": {
          "$ref": "#/definitions/ManifestShellName"
        },
        "enabled": {
          "type": "boolean"
        },
        "maxAttached": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "maxSessions": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    }
  }
}
