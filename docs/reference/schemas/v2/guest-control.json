{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GuestControlSchema",
  "type": "object",
  "required": [
    "authenticate",
    "authenticated",
    "capabilities",
    "capabilitiesRequest",
    "closeStdin",
    "closeStdinResult",
    "controlAck",
    "error",
    "execCancel",
    "execCreate",
    "execCreated",
    "execInspect",
    "execInspected",
    "execList",
    "execListed",
    "execLogChunk",
    "execLogs",
    "execSignal",
    "execWait",
    "execWaited",
    "health",
    "healthRequest",
    "hello",
    "helloOk",
    "limits",
    "outputChunk",
    "protocolVersion",
    "readGuestFile",
    "readGuestFileResult",
    "readOutput",
    "schemaVersion",
    "transport",
    "ttyWinResize",
    "writeStdin",
    "writeStdinResult"
  ],
  "properties": {
    "authenticate": {
      "$ref": "#/definitions/AuthenticateRequest"
    },
    "authenticated": {
      "$ref": "#/definitions/AuthenticateResponse"
    },
    "capabilities": {
      "$ref": "#/definitions/CapabilitiesResponse"
    },
    "capabilitiesRequest": {
      "$ref": "#/definitions/CapabilitiesRequest"
    },
    "closeStdin": {
      "$ref": "#/definitions/CloseStdinRequest"
    },
    "closeStdinResult": {
      "$ref": "#/definitions/CloseStdinResponse"
    },
    "controlAck": {
      "$ref": "#/definitions/ControlAck"
    },
    "error": {
      "$ref": "#/definitions/GuestControlError"
    },
    "execCancel": {
      "$ref": "#/definitions/ExecCancelRequest"
    },
    "execCreate": {
      "$ref": "#/definitions/ExecCreateRequest"
    },
    "execCreated": {
      "$ref": "#/definitions/ExecCreateResponse"
    },
    "execInspect": {
      "$ref": "#/definitions/ExecInspectRequest"
    },
    "execInspected": {
      "$ref": "#/definitions/ExecInspectResponse"
    },
    "execList": {
      "$ref": "#/definitions/ExecListRequest"
    },
    "execListed": {
      "$ref": "#/definitions/ExecListResponse"
    },
    "execLogChunk": {
      "$ref": "#/definitions/ExecLogsResponse"
    },
    "execLogs": {
      "$ref": "#/definitions/ExecLogsRequest"
    },
    "execSignal": {
      "$ref": "#/definitions/ExecSignalRequest"
    },
    "execWait": {
      "$ref": "#/definitions/ExecWaitRequest"
    },
    "execWaited": {
      "$ref": "#/definitions/ExecWaitResponse"
    },
    "health": {
      "$ref": "#/definitions/HealthResponse"
    },
    "healthRequest": {
      "$ref": "#/definitions/HealthRequest"
    },
    "hello": {
      "$ref": "#/definitions/HelloRequest"
    },
    "helloOk": {
      "$ref": "#/definitions/HelloResponse"
    },
    "limits": {
      "$ref": "#/definitions/GuestEffectiveLimits"
    },
    "outputChunk": {
      "$ref": "#/definitions/ReadOutputResponse"
    },
    "protocolVersion": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "readGuestFile": {
      "$ref": "#/definitions/ReadGuestFileRequest"
    },
    "readGuestFileResult": {
      "$ref": "#/definitions/ReadGuestFileResponse"
    },
    "readOutput": {
      "$ref": "#/definitions/ReadOutputRequest"
    },
    "schemaVersion": {
      "$ref": "#/definitions/GuestSchemaVersion"
    },
    "transport": {
      "$ref": "#/definitions/GuestTransportSchema"
    },
    "ttyWinResize": {
      "$ref": "#/definitions/TtyWinResizeRequest"
    },
    "writeStdin": {
      "$ref": "#/definitions/WriteStdinRequest"
    },
    "writeStdinResult": {
      "$ref": "#/definitions/WriteStdinResponse"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ArgvSha256": {
      "type": "string",
      "maxLength": 64,
      "minLength": 1
    },
    "AuthenticateRequest": {
      "type": "object",
      "required": [
        "guestBootId",
        "guestNonce",
        "hostAuthTag",
        "hostNonce",
        "metadata",
        "transcriptVersion"
      ],
      "properties": {
        "guestBootId": {
          "$ref": "#/definitions/GuestBootId"
        },
        "guestNonce": {
          "$ref": "#/definitions/GuestNonce"
        },
        "hostAuthTag": {
          "$ref": "#/definitions/GuestAuthTag"
        },
        "hostNonce": {
          "$ref": "#/definitions/GuestNonce"
        },
        "metadata": {
          "$ref": "#/definitions/GuestRequestMetadata"
        },
        "transcriptVersion": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "AuthenticateResponse": {
      "type": "object",
      "properties": {
        "capabilities": {
          "anyOf": [
            {
              "$ref": "#/definitions/CapabilitiesResponse"
            },
            {
              "type": "null"
            }
          ]
        },
        "capabilitiesHash": {
          "anyOf": [
            {
              "$ref": "#/definitions/CapabilitiesHash"
            },
            {
              "type": "null"
            }
          ]
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestControlError"
            },
            {
              "type": "null"
            }
          ]
        },
        "guestAuthTag": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestAuthTag"
            },
            {
              "type": "null"
            }
          ]
        },
        "health": {
          "anyOf": [
            {
              "$ref": "#/definitions/HealthResponse"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "CapabilitiesHash": {
      "type": "string",
      "maxLength": 128,
      "minLength": 1
    },
    "CapabilitiesRequest": {
      "type": "object",
      "required": [
        "metadata"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/definitions/GuestRequestMetadata"
        }
      },
      "additionalProperties": false
    },
    "CapabilitiesResponse": {
      "type": "object",
      "required": [
        "capabilities",
        "limits",
        "protocolVersion"
      ],
      "properties": {
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GuestCapability"
          },
          "maxItems": 32
        },
        "limits": {
          "$ref": "#/definitions/GuestEffectiveLimits"
        },
        "protocolVersion": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "CloseStdinRequest": {
      "type": "object",
      "required": [
        "metadata",
        "offset"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/definitions/GuestExecRequestMetadata"
        },
        "offset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "CloseStdinResponse": {
      "type": "object",
      "required": [
        "disposition",
        "finalOffset",
        "stdinState"
      ],
      "properties": {
        "disposition": {
          "$ref": "#/definitions/WriteDisposition"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestControlError"
            },
            {
              "type": "null"
            }
          ]
        },
        "finalOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stdinState": {
          "$ref": "#/definitions/StdinState"
        }
      },
      "additionalProperties": false
    },
    "ControlAck": {
      "type": "object",
      "required": [
        "controlSeq",
        "duplicate"
      ],
      "properties": {
        "controlSeq": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "duplicate": {
          "type": "boolean"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestControlError"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "EnvKey": {
      "type": "string",
      "maxLength": 128,
      "minLength": 1
    },
    "EnvValue": {
      "type": "string",
      "maxLength": 8192,
      "minLength": 1
    },
    "EnvVar": {
      "type": "object",
      "required": [
        "key",
        "value"
      ],
      "properties": {
        "key": {
          "$ref": "#/definitions/EnvKey"
        },
        "value": {
          "$ref": "#/definitions/EnvValue"
        }
      },
      "additionalProperties": false
    },
    "ExecCancelReason": {
      "type": "string",
      "enum": [
        "client-disconnect",
        "user-requested",
        "slow-consumer",
        "protocol-error"
      ]
    },
    "ExecCancelRequest": {
      "type": "object",
      "required": [
        "controlSeq",
        "metadata",
        "reason"
      ],
      "properties": {
        "controlSeq": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "metadata": {
          "$ref": "#/definitions/GuestExecRequestMetadata"
        },
        "reason": {
          "$ref": "#/definitions/ExecCancelReason"
        }
      },
      "additionalProperties": false
    },
    "ExecCreateRequest": {
      "type": "object",
      "required": [
        "argv",
        "detached",
        "env",
        "metadata",
        "outputPolicy",
        "stdinOpen",
        "tty"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GuestArg"
          },
          "maxItems": 128,
          "minItems": 1
        },
        "cwd": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestCwd"
            },
            {
              "type": "null"
            }
          ]
        },
        "detached": {
          "type": "boolean"
        },
        "env": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EnvVar"
          },
          "maxItems": 256
        },
        "initialTerminalSize": {
          "anyOf": [
            {
              "$ref": "#/definitions/TerminalSize"
            },
            {
              "type": "null"
            }
          ]
        },
        "metadata": {
          "$ref": "#/definitions/GuestRequestMetadata"
        },
        "outputPolicy": {
          "$ref": "#/definitions/OutputPolicy"
        },
        "stdinOpen": {
          "type": "boolean"
        },
        "tty": {
          "type": "boolean"
        },
        "user": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestUser"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ExecCreateResponse": {
      "type": "object",
      "required": [
        "controlSeq",
        "createdAtMonotonicNs",
        "effectiveLimits",
        "state",
        "stderrCursor",
        "stdoutCursor"
      ],
      "properties": {
        "controlSeq": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "createdAtMonotonicNs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "effectiveLimits": {
          "$ref": "#/definitions/GuestEffectiveLimits"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestControlError"
            },
            {
              "type": "null"
            }
          ]
        },
        "execId": {
          "anyOf": [
            {
              "$ref": "#/definitions/ExecId"
            },
            {
              "type": "null"
            }
          ]
        },
        "state": {
          "$ref": "#/definitions/ExecState"
        },
        "stderrCursor": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stdoutCursor": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "ExecId": {
      "type": "string",
      "maxLength": 128,
      "minLength": 1
    },
    "ExecInspectRequest": {
      "type": "object",
      "required": [
        "metadata"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/definitions/GuestExecRequestMetadata"
        }
      },
      "additionalProperties": false
    },
    "ExecInspectResponse": {
      "type": "object",
      "required": [
        "lastControlSeq",
        "state",
        "stateGeneration",
        "stderrDroppedBytes",
        "stderrEndOffset",
        "stderrStartOffset",
        "stderrTruncatedForRetention",
        "stdinState",
        "stdoutDroppedBytes",
        "stdoutEndOffset",
        "stdoutStartOffset",
        "stdoutTruncatedForRetention"
      ],
      "properties": {
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestControlError"
            },
            {
              "type": "null"
            }
          ]
        },
        "lastControlSeq": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "state": {
          "$ref": "#/definitions/ExecState"
        },
        "stateGeneration": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stderrDroppedBytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stderrEndOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stderrStartOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stderrTruncatedForRetention": {
          "type": "boolean"
        },
        "stdinState": {
          "$ref": "#/definitions/StdinState"
        },
        "stdoutDroppedBytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stdoutEndOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stdoutStartOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stdoutTruncatedForRetention": {
          "type": "boolean"
        },
        "visibleTerminalStatus": {
          "anyOf": [
            {
              "$ref": "#/definitions/TerminalStatus"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ExecListEntry": {
      "description": "One detached exec record summary. Discloses only bounded, non-sensitive metadata: the opaque id, slot, lifecycle state, create time, an argv hash (never the raw argv), and retained-log accounting.",
      "type": "object",
      "required": [
        "argvSha256",
        "createTimeUnix",
        "droppedBytes",
        "execId",
        "slot",
        "state",
        "stderrTruncated",
        "stdoutTruncated"
      ],
      "properties": {
        "argvSha256": {
          "$ref": "#/definitions/ArgvSha256"
        },
        "createTimeUnix": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "droppedBytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "execId": {
          "$ref": "#/definitions/ExecId"
        },
        "slot": {
          "type": "integer",
          "format": "uint32",
          "maximum": 31.0,
          "minimum": 0.0
        },
        "state": {
          "$ref": "#/definitions/ExecState"
        },
        "stderrTruncated": {
          "type": "boolean"
        },
        "stdoutTruncated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ExecListRequest": {
      "description": "Read-only listing of detached execs visible to the same VM token on the same guest boot. Carries no exec id, argv, or output; the boot id binds the request to the current guest generation.",
      "type": "object",
      "required": [
        "guestBootId",
        "metadata"
      ],
      "properties": {
        "guestBootId": {
          "$ref": "#/definitions/GuestBootId"
        },
        "metadata": {
          "$ref": "#/definitions/GuestRequestMetadata"
        }
      },
      "additionalProperties": false
    },
    "ExecListResponse": {
      "type": "object",
      "required": [
        "entries"
      ],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExecListEntry"
          },
          "maxItems": 32
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestControlError"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ExecLogsRequest": {
      "type": "object",
      "required": [
        "maxLen",
        "metadata",
        "offset",
        "stream"
      ],
      "properties": {
        "maxLen": {
          "type": "integer",
          "format": "uint64",
          "maximum": 1048576.0,
          "minimum": 1.0
        },
        "metadata": {
          "$ref": "#/definitions/GuestExecRequestMetadata"
        },
        "offset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stream": {
          "$ref": "#/definitions/OutputStream"
        }
      },
      "additionalProperties": false
    },
    "ExecLogsResponse": {
      "type": "object",
      "required": [
        "data",
        "droppedBytes",
        "endOffset",
        "eof",
        "nextOffset",
        "offset",
        "startOffset",
        "stream",
        "truncated"
      ],
      "properties": {
        "data": {
          "$ref": "#/definitions/GuestOutputBytes"
        },
        "droppedBytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "endOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "eof": {
          "type": "boolean"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestControlError"
            },
            {
              "type": "null"
            }
          ]
        },
        "nextOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "offset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "startOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stream": {
          "$ref": "#/definitions/OutputStream"
        },
        "truncated": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ExecSignalRequest": {
      "type": "object",
      "required": [
        "controlSeq",
        "metadata",
        "signal",
        "target"
      ],
      "properties": {
        "controlSeq": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "metadata": {
          "$ref": "#/definitions/GuestExecRequestMetadata"
        },
        "signal": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "target": {
          "$ref": "#/definitions/SignalTarget"
        }
      },
      "additionalProperties": false
    },
    "ExecState": {
      "type": "string",
      "enum": [
        "created",
        "running",
        "exited",
        "signaled",
        "cancelled",
        "slow-consumer-cancelled",
        "protocol-error",
        "lost-guestd",
        "reaped"
      ]
    },
    "ExecWaitRequest": {
      "type": "object",
      "required": [
        "metadata",
        "timeoutMs"
      ],
      "properties": {
        "knownStateGeneration": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "metadata": {
          "$ref": "#/definitions/GuestExecRequestMetadata"
        },
        "timeoutMs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "ExecWaitResponse": {
      "type": "object",
      "required": [
        "state",
        "stateGeneration",
        "stderrEndOffset",
        "stderrStartOffset",
        "stdoutEndOffset",
        "stdoutStartOffset",
        "timedOut"
      ],
      "properties": {
        "error": {
          "anyOf": [
            {
              "$ref": "#/definitions/GuestControlError"
            },
            {
              "type": "null"
            }
          ]
        },
        "state": {
          "$ref": "#/definitions/ExecState"
        },
        "stateGeneration": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stderrEndOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stderrStartOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stdoutEndOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "stdoutStartOffset": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "timedOut": {
          "type": "boolean"
        },
        "visibleTerminalStatus": {
          "anyOf": [
            {
              "$ref": "#/definitions/TerminalStatus"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "GuestArg": {
      "type": "string",
      "maxLength": 4096,
      "minLength": 1
    },
    "GuestAuthTag": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "maximum": 255.0,
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "GuestBootId": {
      "type": "string",
      "maxLength": 128,
      "minLength": 1
    },
    "GuestCapability": {
      "type": "string",
      "enum": [
        "health",
        "capabilities",
        "exec-attached",
        "exec-detached",
        "exec-tty",
        "exec-logs",
        "tty-resize",
        "signals",
        "read-guest-file"
      ]
    },
    "GuestConnectAckLine": {
      "type": "string",
      "maxLength": 64,
      "minLength": 1
    },
    "GuestConnectAckValue": {
      "type": "string",
      "enum": [
        "opaque-local-port"
      ]
    },
    "GuestConnectRequestLine": {
      "type": "string",
      "maxLength": 64,
      "minLength": 1
    },
    "GuestControlError": {
      "type": "object",
      "required": [
        "kind",
        "remediation"
      ],
      "properties": {
        "kind": {
          "$ref": "#/definitions/GuestControlErrorKind"
        },
        "remediation": {
          "$ref": "#/definitions/HealthRemediation"
        },
        "retryAfterMs": {
          "type": [
