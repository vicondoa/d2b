{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VmAudioSetOutputV1",
  "description": "Output for `d2b audio set-volume` and `d2b audio mute --json` (version 1).",
  "type": "object",
  "required": [
    "applied",
    "channel",
    "command",
    "muted",
    "vm"
  ],
  "properties": {
    "applied": {
      "description": "Whether and how the change was applied.",
      "allOf": [
        {
          "$ref": "#/definitions/AudioSetApplied"
        }
      ]
    },
    "channel": {
      "description": "Channel that was changed.",
      "allOf": [
        {
          "$ref": "#/definitions/AudioChannel"
        }
      ]
    },
    "command": {
      "description": "CLI command string for display/logging.",
      "type": "string"
    },
    "level": {
      "description": "Channel level after the operation (0–100), if known.",
      "anyOf": [
        {
          "$ref": "#/definitions/LevelPercent"
        },
        {
          "type": "null"
        }
      ]
    },
    "muted": {
      "description": "Whether the channel is muted after the operation.",
      "type": "boolean"
    },
    "vm": {
      "description": "Target VM.",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "AudioChannel": {
      "description": "An audio channel controlled by a single operation.",
      "oneOf": [
        {
          "description": "Speaker / playback output volume.",
          "type": "string",
          "enum": [
            "speaker"
          ]
        },
        {
          "description": "Microphone / capture gain.",
          "type": "string",
          "enum": [
            "microphone"
          ]
        }
      ]
    },
    "AudioSetApplied": {
      "description": "Whether a set-volume or mute operation was applied and through which path.",
      "oneOf": [
        {
          "description": "Applied to both host (PipeWire/qemu) and guest (guestd).",
          "type": "string",
          "enum": [
            "host-and-guest"
          ]
        },
        {
          "description": "Applied to host only; guestd enforcement was unavailable or degraded.",
          "type": "string",
          "enum": [
            "host-only"
          ]
        },
        {
          "description": "Applied to guest only (ACA sandbox; no local host audio state written).",
          "type": "string",
          "enum": [
            "guest-only"
          ]
        },
        {
          "description": "No enforcement path was available; the operation was not applied.",
          "type": "string",
          "enum": [
            "unsupported"
          ]
        }
      ]
    },
    "LevelPercent": {
      "description": "Audio level in the range 0..=100.",
      "type": "integer",
      "maximum": 100.0,
      "minimum": 0.0
    }
  }
}
