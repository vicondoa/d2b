{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StatusOutputV2",
  "anyOf": [
    {
      "$ref": "#/definitions/StatusVmOutputV2"
    },
    {
      "$ref": "#/definitions/StatusInventoryOutputV2"
    },
    {
      "$ref": "#/definitions/StatusBridgeCheckOutputV2"
    }
  ],
  "definitions": {
    "ApiReadyErrorV1": {
      "type": "object",
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ApiReadySimple": {
      "type": "string",
      "enum": [
        "yes",
        "pending",
        "timeout"
      ]
    },
    "ApiReadyStatusV1": {
      "anyOf": [
        {
          "$ref": "#/definitions/ApiReadySimple"
        },
        {
          "$ref": "#/definitions/ApiReadyErrorV1"
        }
      ]
    },
    "LivePoolIntegrityOutputV1": {
      "type": "object",
      "required": [
        "repairAttempted",
        "status"
      ],
      "properties": {
        "auditRef": {
          "type": [
            "string",
            "null"
          ]
        },
        "remediation": {
          "type": [
            "string",
            "null"
          ]
        },
        "repairAttempted": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "unknownReason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "PublicReadModelMetadata": {
      "type": "object",
      "required": [
        "deepRefresh",
        "freshness",
        "generation",
        "kind",
        "schemaVersion",
        "sourceFingerprint",
        "updatedAtUnixMs"
      ],
      "properties": {
        "deepRefresh": {
          "type": "string"
        },
        "freshness": {
          "type": "string"
        },
        "generation": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "kind": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "sourceFingerprint": {
          "type": "string"
        },
        "updatedAtUnixMs": {
          "type": "integer",
          "format": "uint128",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "QemuMediaRegistryStatus": {
      "type": "object",
      "required": [
        "state"
      ],
      "properties": {
        "remediation": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "QemuMediaRunnerStatus": {
      "type": "object",
      "required": [
        "preContProgress",
        "role",
        "state"
      ],
      "properties": {
        "preContProgress": {
          "type": "string"
        },
        "qmpReadiness": {
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "type": "string"
        },
        "state": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "QemuMediaSourceStatus": {
      "type": "object",
      "required": [
        "format",
        "mediaRef",
        "readOnly",
        "registry",
        "slot",
        "sourceKind"
      ],
      "properties": {
        "format": {
          "type": "string"
        },
        "mediaRef": {
          "type": "string"
        },
        "readOnly": {
          "type": "boolean"
        },
        "registry": {
          "$ref": "#/definitions/QemuMediaRegistryStatus"
        },
        "slot": {
          "type": "string"
        },
        "sourceKind": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "QemuMediaStatus": {
      "type": "object",
      "required": [
        "firmwareMode",
        "media",
        "runner"
      ],
      "properties": {
        "firmwareMode": {
          "type": "string"
        },
        "media": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/QemuMediaSourceStatus"
          }
        },
        "runner": {
          "$ref": "#/definitions/QemuMediaRunnerStatus"
        }
      },
      "additionalProperties": false
    },
    "RunnerParityOutputV2": {
      "type": "object",
      "required": [
        "declaredRunner",
        "runnerParityOk",
        "runnerParityPath"
      ],
      "properties": {
        "declaredRunner": {
          "type": "string"
        },
        "runnerParityOk": {
          "type": "boolean"
        },
        "runnerParityPath": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "StatusBridgeCheckOutputV2": {
      "type": "object",
      "required": [
        "message",
        "mode",
        "runtime",
        "status"
      ],
      "properties": {
        "message": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "StatusInventoryOutputV2": {
      "type": "object",
      "required": [
        "runtime",
        "vms"
      ],
      "properties": {
        "readModel": {
          "anyOf": [
            {
              "$ref": "#/definitions/PublicReadModelMetadata"
            },
            {
              "type": "null"
            }
          ]
        },
        "runtime": {
          "type": "string"
        },
        "vms": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StatusVmOutputV2"
          }
        }
      },
      "additionalProperties": false
    },
    "StatusServicesOutputV2": {
      "type": "object",
      "required": [
        "microvm",
        "nixling",
        "virtiofsd"
      ],
      "properties": {
        "gpu": {
          "type": [
            "string",
            "null"
          ]
        },
        "microvm": {
          "type": "string"
        },
        "nixling": {
          "type": "string"
        },
        "qemuMedia": {
          "type": [
            "string",
            "null"
          ]
        },
        "snd": {
          "type": [
            "string",
            "null"
          ]
        },
        "swtpm": {
          "type": [
            "string",
            "null"
          ]
        },
        "video": {
          "type": [
            "string",
            "null"
          ]
        },
        "virtiofsd": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "StatusVmOutputV2": {
      "type": "object",
      "required": [
        "declaredRoles",
        "name",
        "pendingRestart",
        "readiness",
        "runtime",
        "services"
      ],
      "properties": {
        "apiReady": {
          "description": "api-ready state from the last vm start in split mode.",
          "anyOf": [
            {
              "$ref": "#/definitions/ApiReadyStatusV1"
            },
            {
              "type": "null"
            }
          ]
        },
        "autostart": {
          "anyOf": [
            {
              "$ref": "#/definitions/VmAutostartPosture"
            },
            {
              "type": "null"
            }
          ]
        },
        "booted": {
          "type": [
            "string",
            "null"
          ]
        },
        "current": {
          "type": [
            "string",
            "null"
          ]
        },
        "declaredRoles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": [
            "string",
            "null"
          ]
        },
        "livePoolIntegrity": {
          "anyOf": [
            {
              "$ref": "#/definitions/LivePoolIntegrityOutputV1"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "pendingRestart": {
          "type": "boolean"
        },
        "qemuMedia": {
          "anyOf": [
            {
              "$ref": "#/definitions/QemuMediaStatus"
            },
            {
              "type": "null"
            }
          ]
        },
        "readiness": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runnerParity": {
          "anyOf": [
            {
              "$ref": "#/definitions/RunnerParityOutputV2"
            },
            {
              "type": "null"
            }
          ]
        },
        "runtime": {
          "type": "string"
        },
        "runtimeCapabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runtimeKind": {
          "type": [
            "string",
            "null"
          ]
        },
        "serviceCapabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "services": {
          "$ref": "#/definitions/StatusServicesOutputV2"
        },
        "unsupportedCapabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "usb": {
          "anyOf": [
            {
              "$ref": "#/definitions/UsbipVmStatus"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "UsbProbeEntryKind": {
      "type": "string",
      "enum": [
        "usbip",
        "qemu-media-slot"
      ]
    },
    "UsbipDurableClaimState": {
      "description": "Wire-compatible state name for the USBIP host-session claim. The backing lock lives under `/run/nixling/locks/usbip`, so the claim survives VM stop/restart and daemon restart during one host boot, but not host reboot.",
      "type": "string",
      "enum": [
        "missing",
        "held-by-desired-owner",
        "held-by-other-owner",
        "stale-owner",
        "corrupt",
        "not-applicable",
        "unknown"
      ]
    },
    "UsbipDurableClaimStatus": {
      "description": "Wire-compatible status object for the USBIP host-session claim. The JSON field is still named `durableClaim` for compatibility; treat it as durable only within the current host boot/session.",
      "type": "object",
      "required": [
        "state"
      ],
      "properties": {
        "ownerVm": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/definitions/UsbipDurableClaimState"
        }
      },
      "additionalProperties": false
    },
    "UsbipGuestImportState": {
      "type": "string",
      "enum": [
        "detached",
        "imported",
        "unavailable",
        "not-applicable",
        "unknown"
      ]
    },
    "UsbipGuestProbeStatus": {
      "type": "object",
      "required": [
        "import"
      ],
      "properties": {
        "import": {
          "$ref": "#/definitions/UsbipGuestImportState"
        }
      },
      "additionalProperties": false
    },
    "UsbipHostBindState": {
      "type": "string",
      "enum": [
        "unbound",
        "bound-to-usbip-host",
        "bound-to-unexpected-driver",
        "device-missing",
        "not-applicable",
        "unknown"
      ]
    },
    "UsbipHostCarrierState": {
      "type": "string",
      "enum": [
        "absent",
        "unavailable",
        "withheld-for-owner",
        "ready",
        "departed-during-probe",
        "not-applicable",
        "unknown"
      ]
    },
    "UsbipHostProbeStatus": {
      "type": "object",
      "required": [
        "bind",
        "carrier",
        "proxy"
      ],
      "properties": {
        "bind": {
          "$ref": "#/definitions/UsbipHostBindState"
        },
        "carrier": {
          "$ref": "#/definitions/UsbipHostCarrierState"
        },
        "proxy": {
          "$ref": "#/definitions/UsbipProxyState"
        }
      },
      "additionalProperties": false
    },
    "UsbipPolicyState": {
      "type": "string",
      "enum": [
        "allowed",
        "denied",
        "missing",
        "not-applicable",
        "unknown"
      ]
    },
    "UsbipProbeDegradedReason": {
      "type": "object",
      "required": [
        "code",
        "remediation",
        "summary"
      ],
      "properties": {
        "code": {
          "$ref": "#/definitions/UsbipProbeDegradedReasonCode"
        },
        "remediation": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "UsbipProbeDegradedReasonCode": {
      "type": "string",
      "enum": [
        "policy-failed",
        "device-departed-before-claim",
        "device-departed-after-lock",
        "device-departed-during-mutation",
        "device-reappeared-with-different-topology",
        "lock-held-by-other-owner",
        "invalid-persisted-lock-claim",
        "carrier-unavailable",
        "host-bind-unavailable",
        "proxy-unavailable",
        "guest-import-unavailable",
        "stale-host-state",
        "stale-guest-state",
        "probe-incomplete",
        "unknown"
      ]
    },
    "UsbipProbeEntry": {
      "type": "object",
      "required": [
        "busId",
        "env",
        "lockPath",
        "status",
        "vm"
      ],
      "properties": {
        "busId": {
          "type": "string"
        },
        "candidateBusIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "degradedReasons": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/UsbipProbeDegradedReason"
          }
        },
        "durableClaim": {
          "description": "USBIP host-session claim status. Serialized as `durableClaim` for compatibility with existing clients.",
          "default": {
            "state": "missing"
          },
          "allOf": [
            {
              "$ref": "#/definitions/UsbipDurableClaimStatus"
            }
          ]
        },
        "env": {
          "type": "string"
        },
        "followUpCommand": {
          "type": [
            "string",
            "null"
          ]
        },
        "guest": {
          "default": {
            "import": "unknown"
          },
          "allOf": [
            {
              "$ref": "#/definitions/UsbipGuestProbeStatus"
            }
          ]
        },
        "host": {
          "default": {
            "bind": "unknown",
            "carrier": "unknown",
            "proxy": "unknown"
          },
          "allOf": [
            {
              "$ref": "#/definitions/UsbipHostProbeStatus"
            }
          ]
        },
        "kind": {
          "$ref": "#/definitions/UsbProbeEntryKind"
        },
        "lockPath": {
          "type": "string"
        },
        "mediaRef": {
          "type": [
            "string",
            "null"
          ]
        },
        "ownerVm": {
          "type": [
            "string",
            "null"
          ]
        },
        "remediationCommands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "slot": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceKind": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/UsbipProbeStatus"
        },
        "topologyPolicy": {
          "default": {
            "policy": "unknown",
            "topology": "unknown"
          },
          "allOf": [
            {
              "$ref": "#/definitions/UsbipTopologyPolicyStatus"
            }
          ]
        },
        "vm": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "UsbipProbeStatus": {
      "type": "string",
      "enum": [
        "bound",
        "unbound",
        "degraded",
        "enrollable",
        "enrolled",
        "stale",
        "direct-config",
        "unknown"
      ]
    },
    "UsbipProxyState": {
      "type": "string",
      "enum": [
        "not-declared",
        "stopped",
        "starting",
        "listening",
        "stale",
        "failed",
        "not-applicable",
        "unknown"
      ]
    },
    "UsbipTopologyPolicyStatus": {
      "type": "object",
      "required": [
        "policy",
        "topology"
      ],
      "properties": {
        "policy": {
          "$ref": "#/definitions/UsbipPolicyState"
        },
        "topology": {
          "$ref": "#/definitions/UsbipTopologyState"
        }
      },
      "additionalProperties": false
    },
    "UsbipTopologyState": {
      "type": "string",
      "enum": [
        "match",
        "mismatch",
        "incomplete",
        "not-observed",
        "not-applicable",
        "unknown"
      ]
    },
    "UsbipVmStatus": {
      "type": "object",
      "required": [
        "degraded",
        "entries"
      ],
      "properties": {
        "degraded": {
          "type": "boolean"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/UsbipProbeEntry"
          }
        }
      },
      "additionalProperties": false
    },
    "VmAutostartPosture": {
      "type": "object",
      "required": [
        "mode",
        "reason"
      ],
      "properties": {
        "mode": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
