{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StatusOutputV2",
  "anyOf": [
    {
      "$ref": "#/definitions/StatusVmOutputV2"
    },
    {
      "$ref": "#/definitions/StatusInventoryOutputV2"
    },
    {
      "$ref": "#/definitions/StatusBridgeCheckOutputV2"
    }
  ],
  "definitions": {
    "ApiReadyErrorV1": {
      "type": "object",
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ApiReadySimple": {
      "type": "string",
      "enum": [
        "yes",
        "pending",
        "timeout"
      ]
    },
    "ApiReadyStatusV1": {
      "anyOf": [
        {
          "$ref": "#/definitions/ApiReadySimple"
        },
        {
          "$ref": "#/definitions/ApiReadyErrorV1"
        }
      ]
    },
    "LivePoolIntegrityOutputV1": {
      "type": "object",
      "required": [
        "repairAttempted",
        "status"
      ],
      "properties": {
        "auditRef": {
          "type": [
            "string",
            "null"
          ]
        },
        "remediation": {
          "type": [
            "string",
            "null"
          ]
        },
        "repairAttempted": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "unknownReason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "QemuMediaRegistryStatus": {
      "type": "object",
      "required": [
        "state"
      ],
      "properties": {
        "remediation": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "QemuMediaRunnerStatus": {
      "type": "object",
      "required": [
        "preContProgress",
        "role",
        "state"
      ],
      "properties": {
        "preContProgress": {
          "type": "string"
        },
        "qmpReadiness": {
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "type": "string"
        },
        "state": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "QemuMediaSourceStatus": {
      "type": "object",
      "required": [
        "format",
        "mediaRef",
        "readOnly",
        "registry",
        "slot",
        "sourceKind"
      ],
      "properties": {
        "format": {
          "type": "string"
        },
        "mediaRef": {
          "type": "string"
        },
        "readOnly": {
          "type": "boolean"
        },
        "registry": {
          "$ref": "#/definitions/QemuMediaRegistryStatus"
        },
        "slot": {
          "type": "string"
        },
        "sourceKind": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "QemuMediaStatus": {
      "type": "object",
      "required": [
        "firmwareMode",
        "media",
        "runner"
      ],
      "properties": {
        "firmwareMode": {
          "type": "string"
        },
        "media": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/QemuMediaSourceStatus"
          }
        },
        "runner": {
          "$ref": "#/definitions/QemuMediaRunnerStatus"
        }
      },
      "additionalProperties": false
    },
    "RunnerParityOutputV2": {
      "type": "object",
      "required": [
        "declaredRunner",
        "runnerParityOk",
        "runnerParityPath"
      ],
      "properties": {
        "declaredRunner": {
          "type": "string"
        },
        "runnerParityOk": {
          "type": "boolean"
        },
        "runnerParityPath": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "StatusBridgeCheckOutputV2": {
      "type": "object",
      "required": [
        "message",
        "mode",
        "runtime",
        "status"
      ],
      "properties": {
        "message": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "StatusInventoryOutputV2": {
      "type": "object",
      "required": [
        "runtime",
        "vms"
      ],
      "properties": {
        "runtime": {
          "type": "string"
        },
        "vms": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StatusVmOutputV2"
          }
        }
      },
      "additionalProperties": false
    },
    "StatusServicesOutputV2": {
      "type": "object",
      "required": [
        "microvm",
        "nixling",
        "virtiofsd"
      ],
      "properties": {
        "gpu": {
          "type": [
            "string",
            "null"
          ]
        },
        "microvm": {
          "type": "string"
        },
        "nixling": {
          "type": "string"
        },
        "qemuMedia": {
          "type": [
            "string",
            "null"
          ]
        },
        "snd": {
          "type": [
            "string",
            "null"
          ]
        },
        "swtpm": {
          "type": [
            "string",
            "null"
          ]
        },
        "video": {
          "type": [
            "string",
            "null"
          ]
        },
        "virtiofsd": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "StatusVmOutputV2": {
      "type": "object",
      "required": [
        "declaredRoles",
        "name",
        "pendingRestart",
        "readiness",
        "runtime",
        "services"
      ],
      "properties": {
        "apiReady": {
          "description": "api-ready state from the last vm start in split mode.",
          "anyOf": [
            {
              "$ref": "#/definitions/ApiReadyStatusV1"
            },
            {
              "type": "null"
            }
          ]
        },
        "autostart": {
          "anyOf": [
            {
              "$ref": "#/definitions/VmAutostartPosture"
            },
            {
              "type": "null"
            }
          ]
        },
        "booted": {
          "type": [
            "string",
            "null"
          ]
        },
        "current": {
          "type": [
            "string",
            "null"
          ]
        },
        "declaredRoles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": [
            "string",
            "null"
          ]
        },
        "livePoolIntegrity": {
          "anyOf": [
            {
              "$ref": "#/definitions/LivePoolIntegrityOutputV1"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "pendingRestart": {
          "type": "boolean"
        },
        "qemuMedia": {
          "anyOf": [
            {
              "$ref": "#/definitions/QemuMediaStatus"
            },
            {
              "type": "null"
            }
          ]
        },
        "readiness": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runnerParity": {
          "anyOf": [
            {
              "$ref": "#/definitions/RunnerParityOutputV2"
            },
            {
              "type": "null"
            }
          ]
        },
        "runtime": {
          "type": "string"
        },
        "runtimeKind": {
          "type": [
            "string",
            "null"
          ]
        },
        "services": {
          "$ref": "#/definitions/StatusServicesOutputV2"
        },
        "unsupportedCapabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "VmAutostartPosture": {
      "type": "object",
      "required": [
        "mode",
        "reason"
      ],
      "properties": {
        "mode": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
