+/// Single shared memory region descriptor.
+#[repr(C, packed)]
+#[derive(Default, Copy, Clone, Debug)]
+pub struct VhostSharedMemoryRegion {
+    /// The shared memory region id.
+    pub id: u8,
+    /// Padding for alignment / wire-format compat.
+    pub padding: [u8; 7],
+    /// The length of the shared memory region.
+    pub length: u64,
+}
+
+// SAFETY: VhostSharedMemoryRegion is POD; all fields are scalars.
+unsafe impl ByteValued for VhostSharedMemoryRegion {}
+
+impl VhostUserShMemConfig {
+    /// Convert to (id, length) regions. Scans full 0..256 because
+    /// backends populate memory_sizes by id, not by position.
+    pub fn regions(&self) -> Vec<VhostSharedMemoryRegion> {
+        (0..256usize)
+            .filter(|&i| self.memory_sizes[i] != 0)
+            .map(|i| VhostSharedMemoryRegion { id: i as u8, padding: [0; 7], length: self.memory_sizes[i] })
+            .collect()
+    }
+}
