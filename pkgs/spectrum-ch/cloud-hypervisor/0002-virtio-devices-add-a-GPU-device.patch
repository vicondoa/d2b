+fn virtio_mem_thread_rules() -> Vec<(i64, Vec<SeccompRule>)> {
+    vec![
+        (libc::SYS_fallocate, vec![]),
+        (libc::SYS_ioctl, create_virtio_mem_ioctl_seccomp_rule()),
+        (libc::SYS_recvfrom, vec![]),
+        (libc::SYS_sendmsg, vec![]),
