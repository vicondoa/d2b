+
+// Size of a dirty page for vhost-user.
+const VHOST_LOG_PAGE: u64 = 0x1000;
+
+#[derive(Debug, Clone)]
+pub struct VhostUserConfig {
+    pub socket: String,
+    pub num_queues: usize,
+    pub queue_size: u16,
+}
+
