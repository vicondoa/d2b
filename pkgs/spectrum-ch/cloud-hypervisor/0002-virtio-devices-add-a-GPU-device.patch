+fn create_data(path: &str) -> Result<String, Error> {
+    let mut data = String::default();
+    if path == "-" {
+        std::io::stdin()
+            .read_to_string(&mut data)
+            .map_err(Error::ReadingStdin)?;
+    } else {
+        data = std::fs::read_to_string(path).map_err(Error::ReadingFile)?;
+    }
+
+    Ok(data)
+}
