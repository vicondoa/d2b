+                &aml::Name::new("_STA".into(), &(0xF_usize)),
+                &aml::Name::new(
+                    "_CRS".into(),
+                    &aml::ResourceTemplate::new(vec![&aml::Memory32Fixed::new(
+                        true,
+                        layout::TPM_START.0 as u32,
